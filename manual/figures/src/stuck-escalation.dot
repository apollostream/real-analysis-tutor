digraph StuckEscalation {
    bgcolor="transparent";
    rankdir=TB;
    fontname="Charter,Georgia,serif";
    fontsize=11;
    node [fontname="Charter,Georgia,serif", fontsize=11, shape=box, style="rounded,filled",
          fillcolor="#E8EDF5", color="#2B4C7E", penwidth=1.2, margin="0.18,0.12"];
    edge [fontname="Charter,Georgia,serif", fontsize=10, color="#6B7280", arrowsize=0.8, penwidth=1.3];

    labelloc="t";
    label=<<B>Stuck-state escalation</B> — strict order, never skip (skills/stuck/SKILL.md)>;

    l1 [label=<<B>Level 1</B> — Solow Forward-Backward<BR/><FONT POINT-SIZE="9.5">always the starting point,<BR/>no exception</FONT>>];
    l2 [label=<<B>Level 2</B> — Revised Recovery Protocol<BR/>(D-L-M-K + Pólya)<BR/><FONT POINT-SIZE="9.5">when Level 1 stalls</FONT>>];
    l3 [label=<<B>Level 3</B> — Framework Reframe<BR/>(Velleman / Eccles / Hammack)<BR/><FONT POINT-SIZE="9.5">when Level 2 fails twice</FONT>>];
    l4 [label=<<B>Level 4</B> — Direct conceptual<BR/>intervention<BR/><FONT POINT-SIZE="9.5">only after 1–3 all documented<BR/>as failed — concepts only,<BR/>never a step of the proof</FONT>>, fillcolor="#F3E3E3", color="#8C3B3B"];

    l1 -> l2 [label="Level 1 exhausted"];
    l2 -> l3 [label="2 full D-L-M-K passes\nfail"];
    l3 -> l4 [label="documented failure,\nnot just \"feels slow\""];

    neverskip [label="never skip a level\nnever jump ahead because\na level \"feels slow\"", shape=note, fillcolor="#FBF9F5", color="#8C3B3B", fontcolor="#8C3B3B", fontsize=9.5];
    neverskip -> l1 [style=dotted, arrowhead=none, color="#8C3B3B", constraint=false];
    neverskip -> l4 [style=dotted, arrowhead=none, color="#8C3B3B", constraint=false];

    analogy [label=<Pólya Step 3 (Analogy) within Level 2<BR/>is gated: not offered before <B>Phase 4</B><BR/><FONT POINT-SIZE="9">thin Ledger ⇒ analogy prompt wastes the attempt</FONT>>, shape=note, fillcolor="#FBF9F5", color="#2B4C7E", fontsize=9.5];
    analogy -> l2 [style=dotted, arrowhead=none, color="#2B4C7E"];
}
